{
  # Programs
  desktop = "bspwm"; # can be 'bspwm'
  terminal = "kitty"; # can be 'kitty'
  editor = "vscode"; # can be 'vscode' or 'neovim'
  browser = "firefox"; # can be 'firefox'
  shell = "fish"; # can be 'bash', 'zsh' or 'fish'

  # Hardware
  videoDriver = "amdgpu"; # can be 'nvidia', 'amdgpu', or 'intel'
  bluetoothSupport = false;

  # Localization
  timezone = "Europe/London";
  locale = "en_GB.UTF-8";
  # clock24h = true; # unused.
  kbdLayout = "gb";
  kbdVariant = "extd";
  consoleKeymap = "uk";
}
