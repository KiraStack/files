# Console
super + Return
  kitty

# Browser
super + w
  firefox

# File Manager
# super + n
#   thunar

# Program Launcher
super + d
  rofi -show drun

# Clipboard manager
super + v
  clipcat-menu

# Screenshot
super + p
  screenshot | wl-copy

# Focus
super + {h,j,k,l}
  bspc node -f {west,south,north,east}

# Move windows
super + shift + {h,j,k,l}
  bspc node -m {west,south,north,east}

# Toggle state
super + f
  bspc node -t floating
super + g
  bspc node -t fullscreen

# Switch desktops
super + {1-9}
  bspc desktop -f ^{1-9}

# Switch and move focused node to desktop 1
super + shift + 1
  bspc node -d ^1 && bspc desktop -f ^1

# Switch and move focused node to desktop 2
super + shift + 2
  bspc node -d ^2 && bspc desktop -f ^2

# Switch and move focused node to desktop 3
super + shift + 3
  bspc node -d ^3 && bspc desktop -f ^3

# Switch and move focused node to desktop 4
super + shift + 4
  bspc node -d ^4 && bspc desktop -f ^4

# Switch and move focused node to desktop 5
super + shift + 5
  bspc node -d ^5 && bspc desktop -f ^5

# Switch and move focused node to desktop 6
super + shift + 6
  bspc node -d ^6 && bspc desktop -f ^6

# Switch and move focused node to desktop 7
super + shift + 7
  bspc node -d ^7 && bspc desktop -f ^7

# Switch and move focused node to desktop 8
super + shift + 8
  bspc node -d ^8 && bspc desktop -f ^8

# Switch and move focused node to desktop 9
super + shift + 9
  bspc node -d ^9 && bspc desktop -f ^9

# Close window
super + q
  bspc node -c

# Volume management
XF86AudioRaiseVolume
  volume change up
XF86AudioLowerVolume
  volume change down
XF86AudioMute
  volume -D pulse sset Master toggle-mute

# Brightness management
XF86MonBrightnessUp
  brightness change up
XF86MonBrightnessDown
  brightness change down

# Restart bspwm
super + alt + w
  bspc wm -r
