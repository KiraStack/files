; Constants
(defvar debug 0)

; Queries
(defpoll date :interval "1m" "date +%d/%m")
(defpoll time :interval "1m" "date +%H:%M")

; Listeners
(deflisten battery "tasks/battery")
(deflisten microphone "tasks/microphone")
(deflisten network "tasks/network")
(deflisten speakers "tasks/speakers")
(deflisten workspaces "tasks/workspaces")

; Headers
(include "bar/eww.yuck")
